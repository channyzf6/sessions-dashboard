{
  "name": "web-view-mcp",
  "version": "0.2.0",
  "description": "MCP server that lets one or more Claude Code sessions share a live browser window via a long-lived daemon.",
  "type": "module",
  "main": "index.mjs",
  "bin": {
    "web-view-mcp": "./index.mjs",
    "web-view-daemon": "./daemon.mjs"
  },
  "scripts": {
    "start": "node index.mjs",
    "daemon": "node daemon.mjs",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "playwright": "^1.48.0"
  },
  "engines": {
    "node": ">=18"
  }
}
