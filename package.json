{
  "name": "sessions-dashboard",
  "version": "0.4.0",
  "description": "A live dashboard for every Claude Code / Gemini CLI / Codex CLI session you're running. See activity in real time, organize sessions into groups, and share a browser across sessions.",
  "type": "module",
  "main": "index.mjs",
  "bin": {
    "sessions-dashboard": "./bin/sessions-dashboard.mjs"
  },
  "files": [
    "bin/sessions-dashboard.mjs",
    "index.mjs",
    "daemon.mjs",
    "lib/",
    "data/dashboards.json",
    "data/sessions.html",
    "!lib/host/__fixtures__",
    "!lib/host/*.test.mjs"
  ],
  "scripts": {
    "start": "node bin/sessions-dashboard.mjs",
    "test": "node --test lib/host/",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "playwright": "^1.48.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/channyzf6/sessions-dashboard.git"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "gemini-cli",
    "codex-cli",
    "dashboard",
    "agent-observability"
  ],
  "license": "MIT"
}
